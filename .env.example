# Financial Modeling Prep API Key
# Get your free API key at: https://financialmodelingprep.com/developer
FMP_API_KEY=YOUR_FMP_API_KEY

# DeepSeek API Key
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# DeepSeek Base URL (default: https://api.deepseek.com/v1)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek Model (deepseek-chat or deepseek-reasoner, default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# Adanos Finance API Key (optional, enables retail sentiment insights)
ADANOS_API_KEY=YOUR_ADANOS_API_KEY

# Adanos Base URL (optional, default: https://api.adanos.org)
ADANOS_BASE_URL=https://api.adanos.org
